# ─────────────────────────────────────────────────────────────────────────────
# Hermes — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to client. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Webhook secret for the storage → analysis-job trigger endpoint.
# Set this to any strong random string, then configure it as an HTTP header
# in the Supabase Database Webhook: Dashboard → Database → Webhooks
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-here

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Pin to a specific model version — provenance requirement (see ADR-007)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Document AI ────────────────────────────────────────────────────────
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
# Path to service account JSON (local dev only — use secret manager in prod)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ── Email Ingestion (Postmark or Resend) ──────────────────────────────────────
INBOUND_EMAIL_TOKEN=your-webhook-token-here
INBOUND_EMAIL_ADDRESS=deals@hermes.app

# ── Trigger.dev ───────────────────────────────────────────────────────────────
# Found in: trigger.dev → Project Settings → API Keys
# Note: TRIGGER_SECRET_KEY (not TRIGGER_API_KEY) is the correct var for v3 SDK
TRIGGER_SECRET_KEY=tr_dev_...your-secret-key-here
TRIGGER_PROJECT_ID=proj_...your-project-id-here
TRIGGER_API_URL=https://api.trigger.dev

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry (not yet configured — create Linear ticket when ready) ─────────────
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ── Posthog (not yet configured — create Linear ticket when ready) ─────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
