# Environment Variables — Hermes
# Copy this file to .env.local and fill in your values
# Never commit .env.local or any file with real secrets

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry (not yet configured) ───────────────────────────────────────────────
# Found in: sentry.io → Project → Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# ── Posthog (not yet configured) ──────────────────────────────────────────────
# Found in: posthog.com → Project → Settings
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
